# grab the container holding the nightly gmsh binary
FROM ghcr.io/malteschoen/gmsh:arm64 AS binary-holder

#grab a slim (eyeroll) version of python
FROM python:3.9-slim AS sfepy-python-builder

#grab stuff needed for building pip-wheels (git)
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive TZ=Etc/UTC \
    apt-get install -y --no-install-recommends \
	git \
	build-essential 

# Upgrade pip and install the wheel package
RUN pip install --upgrade pip wheel

# Download/build  numpy/sfepy and requirements and store them under /wheels
RUN pip wheel "numpy<2.0" "sfepy" -w /wheels

# check if wheels are present
RUN ls -lah /wheels

#appears to borked? no it isnt...
#RUN pip install --no-cache-dir --break-system-packages git+https://github.com/sfepy/sfepy.git@master

#grab a slim (eyeroll) version of python
FROM python:3.9-slim AS runner

#copy over wheels from builder and install them
COPY --from=sfepy-python-builder /wheels /wheels
RUN pip install --no-cache-dir /wheels/*.whl

# Copy installed gmsh files from binary-holder
COPY --from=binary-holder /usr/local/bin/gmsh /usr/local/bin/gmsh

# Copy required libs from builder, currently optimized for python:3.12-slim in aarch64
COPY --from=binary-holder /lib/aarch64-linux-gnu/libTK*.so.7.8 /lib/aarch64-linux-gnu/
