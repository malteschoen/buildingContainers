# Stage 1: Build gmsh from source
FROM python:3.12-slim AS builder

# Install build dependencies - will need cleanup in the future
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    libgomp1 \
    libocct-foundation-dev \
    libocct-data-exchange-dev \
    libocct-modeling-algorithms-dev \
    libocct-modeling-data-dev \
    libocct-ocaf-dev \
    cmake \
    build-essential \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

#set the environmental variables to use my big /shared/tmp as TMP instead of the tiny default one
ENV TMPDIR=/shared/tmp TEMP=/shared/tmp TMP=/shared/tmp

# Set the working directory
WORKDIR /shared/workspace

# Clone gmsh repository - comment out if already cloned
RUN git clone https://gitlab.onelab.info/gmsh/gmsh.git

# Create build directory and run cmake with FLTK disabled
# might also use -DENABLE_BUILD_DYNAMIC=1 for gmsh APIs (e.g. Python)
# probably not needed, like the 'make install'
# make sure to comment out the 'mkdir build' if it already exists
WORKDIR /shared/workspace/gmsh
RUN mkdir build 
RUN cd build && \
    cmake -DENABLE_FLTK=0 -DENABLE_BUILD_DYNAMIC=0 -DENABLE_OCC=1 -DENABLE_WINSLOWUNTANGLER=1 .. && \
    make -j$(nproc) && \
    make install

# Stage 2: Minimal runtime container with gmsh executable and libs
FROM python:3.12-slim AS runner

# Copy installed gmsh files from builder
COPY --from=builder /usr/local/bin/gmsh /usr/local/bin/gmsh

# Copy required libs from builder, currently optimized for python:3.12-slim in aarch64
COPY --from=builder /lib/aarch64-linux-gnu/libTK*.so.7.8 /lib/aarch64-linux-gnu/
COPY --from=builder \
        /lib/aarch64-linux-gnu/libgomp.so.1 \
	/lib/aarch64-linux-gnu/libtbb.so.12  \
	/lib/aarch64-linux-gnu/libX11.so.6  \
	/lib/aarch64-linux-gnu/libfontconfig.so.1 \ 
	/lib/aarch64-linux-gnu/libfreeimage.so.3  \
	/lib/aarch64-linux-gnu/libfreetype.so.6  \
	/lib/aarch64-linux-gnu/libxcb.so.1  \
	/lib/aarch64-linux-gnu/libexpat.so.1  \
	/lib/aarch64-linux-gnu/libjxrglue.so.0  \
	/lib/aarch64-linux-gnu/libjpeg.so.62  \
	/lib/aarch64-linux-gnu/libopenjp2.so.7  \
	/lib/aarch64-linux-gnu/libpng16.so.16  \
	/lib/aarch64-linux-gnu/libraw.so.23  \
	/lib/aarch64-linux-gnu/libtiff.so.6  \
	/lib/aarch64-linux-gnu/libwebpmux.so.3  \
	/lib/aarch64-linux-gnu/libOpenEXR-3_1.so.30  \
	/lib/aarch64-linux-gnu/libIex-3_1.so.30  \
	/lib/aarch64-linux-gnu/libImath-3_1.so.29  \
	/lib/aarch64-linux-gnu/libpng16.so.16 \
